# Database (your local Postgres)
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_NAME=forge

# Security — generate with: openssl rand -hex 32
SECRET_KEY=

# Embeddings
# VOYAGE_API_KEY — Removed. Forge now runs embeddings locally
# (sentence-transformers, all-MiniLM-L6-v2). No API key or internet
# required after the first ~90MB model download.

# Forge workspace (where agents read/write files)
FORGE_WORKSPACE=~/forge-workspace

# Ports (change if you have conflicts with other projects)
# BACKEND_PORT=8001   # uncomment if 8000 is taken
# FRONTEND_PORT=3001  # uncomment if 3000 is taken

# AI providers (add in Settings UI, not here)
# Keys are stored encrypted in the database
